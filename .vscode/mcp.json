{
	"servers": {
		"greenhouse/greenhouse-mcp-readonly": {
			"type": "stdio",
			"command": "pnpm",
			"args": [
				"mcp:greenhouse"
			],
			"env": {
				"GREENHOUSE_MCP_API_BASE_URL": "${input:GREENHOUSE_MCP_API_BASE_URL}",
				"GREENHOUSE_MCP_CONSUMER_TOKEN": "${input:GREENHOUSE_MCP_CONSUMER_TOKEN}",
				"GREENHOUSE_MCP_EXTERNAL_SCOPE_TYPE": "${input:GREENHOUSE_MCP_EXTERNAL_SCOPE_TYPE}",
				"GREENHOUSE_MCP_EXTERNAL_SCOPE_ID": "${input:GREENHOUSE_MCP_EXTERNAL_SCOPE_ID}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "v1-read-only"
		},
		"microsoft/playwright-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@playwright/mcp@latest"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.0.1-seed"
		},
		"io.github.getsentry/sentry-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@sentry/mcp-server@0.25.0"
			],
			"env": {
				"SENTRY_ACCESS_TOKEN": "${input:SENTRY_ACCESS_TOKEN}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "0.25.0"
		}
	},
	"inputs": [
		{
			"id": "GREENHOUSE_MCP_API_BASE_URL",
			"type": "promptString",
			"description": "Greenhouse API base URL for the local read-only MCP server"
		},
		{
			"id": "GREENHOUSE_MCP_CONSUMER_TOKEN",
			"type": "promptString",
			"description": "Greenhouse MCP consumer token",
			"password": true
		},
		{
			"id": "GREENHOUSE_MCP_EXTERNAL_SCOPE_TYPE",
			"type": "promptString",
			"description": "Greenhouse MCP external scope type (organization, client, space, internal)"
		},
		{
			"id": "GREENHOUSE_MCP_EXTERNAL_SCOPE_ID",
			"type": "promptString",
			"description": "Greenhouse MCP external scope identifier"
		},
		{
			"id": "SENTRY_ACCESS_TOKEN",
			"type": "promptString",
			"description": "Your Sentry user authentication token",
			"password": true
		}
	]
}
