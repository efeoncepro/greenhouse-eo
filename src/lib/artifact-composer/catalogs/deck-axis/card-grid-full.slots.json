{
  "template": "CardGridFull",
  "version": "0.1",
  "viewport": { "width": 1920, "height": 1080 },
  "slots": {
    "eyebrow": {
      "selector": "[data-slot='eyebrow']",
      "type": "string",
      "required": false,
      "constraints": { "maxCharacters": 26, "maxLines": 1, "overflow": "reject" }
    },
    "headline": {
      "selector": "[data-slot='headline']",
      "type": "rich-string",
      "required": true,
      "constraints": { "maxCharacters": 62, "maxLines": 4, "allowedTags": ["em"], "overflow": "reject" }
    },
    "intro": {
      "selector": "[data-slot='intro']",
      "type": "string",
      "required": true,
      "constraints": { "maxCharacters": 112, "maxLines": 4, "overflow": "reject" }
    },
    "highlight": {
      "selector": "[data-slot='highlight']",
      "type": "rich-string",
      "required": false,
      "constraints": { "maxCharacters": 106, "maxLines": 4, "allowedTags": ["em"], "overflow": "reject" }
    },
    "panelQuestion": {
      "selector": "[data-slot='panelQuestion']",
      "type": "string",
      "required": true,
      "constraints": { "maxCharacters": 46, "maxLines": 2, "overflow": "reject" }
    },
    "capabilities": {
      "selector": "[data-slot='capabilities']",
      "type": "array",
      "required": true,
      "constraints": { "minItems": 4, "maxItems": 6, "overflow": "reject" },
      "item": {
        "type": "object",
        "shape": {
          "kind": {
            "type": "enum",
            "required": true,
            "values": ["search", "conversation", "authoring", "data", "measurement", "governance"],
            "resolver": "card-grid-capability-icon"
          },
          "title": { "type": "string", "required": true, "maxCharacters": 26, "maxLines": 1 },
          "description": { "type": "string", "required": true, "maxCharacters": 68, "maxLines": 2 }
        }
      }
    }
  },
  "presentation": {
    "brandSurface": "canonical-rich-deck-gradient, full bleed",
    "cards": "milky glassmorphism, 2-column grid; card height is driven by content — title must stay on one line",
    "icons": "Solar Bold inline SVG inside the teal chip (.card .ic svg); kind selects the icon, it is never authored content"
  }
}
