{
  "template": "CoverFull",
  "version": "0.1",
  "viewport": {
    "width": 1920,
    "height": 1080
  },
  "slots": {
    "clientLogo": {
      "selector": "[data-slot='clientLogo']",
      "type": "asset",
      "required": true,
      "audience": "client_facing",
      "resolver": "client-brand-mark",
      "agentInput": "assetId",
      "agentMayOverridePresentation": false,
      "constraints": {
        "boxWidth": 500,
        "boxHeight": 132,
        "fit": "contain",
        "normalization": "native-on-dark",
        "opticalAlignment": "center",
        "altFrom": "clientDisplayName"
      }
    },
    "proposalKind": {
      "selector": "[data-slot='proposalKind']",
      "type": "enum",
      "required": true,
      "resolver": "proposal-kind-label",
      "agentInput": "proposalKind",
      "agentMayOverridePresentation": false,
      "values": {
        "technical": "Propuesta Técnica",
        "economic": "Propuesta Económica",
        "executive": "Propuesta Ejecutiva",
        "combined": "Propuesta Técnica y Económica"
      },
      "constraints": {
        "maxCharacters": 34,
        "overflow": "reject"
      }
    }
  }
}
