{
  "template": "StatSplit",
  "figmaNodeId": "7:13485",
  "version": "0.1",
  "viewport": { "width": 1920, "height": 1080 },
  "slots": {
    "eyebrow": { "selector": "[data-slot='eyebrow']", "type": "string", "required": true, "constraints": { "maxCharacters": 32, "maxLines": 1, "overflow": "reject" } },
    "leftVisual": { "selector": "[data-slot='leftVisual']", "type": "asset", "required": true, "resolver": "deck-stat-concept-visual", "defaultAsset": "assets/stat-opportunity-visual.png", "sourceFigmaNodeId": "7:13519", "constraints": { "allowedKinds": ["concept", "object", "illustration"], "maxWidth": 205, "maxHeight": 205, "fit": "contain", "noHumanPortrait": true, "overflow": "reject" } },
    "title": { "selector": "[data-slot='title']", "type": "rich-string", "required": true, "constraints": { "maxCharacters": 106, "maxLines": 3, "allowedTags": ["em"], "overflow": "reject" } },
    "narrative": {
      "selector": "[data-slot='narrative']", "type": "array", "required": true,
      "constraints": { "minItems": 1, "maxItems": 2, "maxCharactersPerItem": 220, "overflow": "reject" },
      "item": { "type": "rich-string", "allowedTags": ["strong"] }
    },
    "outcomesEyebrow": { "selector": "[data-slot='outcomesEyebrow']", "type": "string", "required": true, "constraints": { "maxCharacters": 32, "maxLines": 1, "overflow": "reject" } },
    "outcomesTitle": { "selector": "[data-slot='outcomesTitle']", "type": "string", "required": true, "constraints": { "maxCharacters": 74, "maxLines": 3, "overflow": "reject" } },
    "goals": {
      "selector": "[data-slot='goals']", "type": "array", "required": true,
      "constraints": { "minItems": 3, "maxItems": 5, "overflow": "reject", "quantifiedClaimsRequireEvidenceRef": true },
      "item": { "type": "object", "shape": {
        "kind": { "type": "enum", "values": ["visibility", "citability", "coherence", "learning", "growth"], "required": true, "resolver": "stat-goal-icon" },
        "title": { "type": "string", "maxCharacters": 42, "required": true },
        "metric": { "type": "string", "maxCharacters": 30, "required": false, "requires": ["evidenceRef"], "presentation": "Poppins Black Italic; renderer omits when empty" },
        "body": { "type": "rich-string", "maxCharacters": 118, "allowedTags": ["strong"], "required": true },
        "evidenceRef": { "type": "string", "required": false, "consumer": "validation-only" }
      }}
    }
  }
}
