    {
      "path": "84",
      "depth": 0,
      "blockName": "core/quote",
      "attrs": {},
      "text": "Una acción fácil de invocar y difícil de controlar no es agentic readiness. Es deuda operativa con una interfaz nueva.",
      "innerBlockCount": 0,
      "fingerprint": "87652ae2da262be52ca34a5790852cb25e27dccbc83b788ee389c561aa251147",
