      "path": "72",
      "depth": 0,
      "blockName": "core/paragraph",
      "attrs": {},
      "text": "La preparación agéntica no comienza instalando un protocolo. Comienza eligiendo una tarea real y reduciendo la ambigüedad que existe alrededor de ella.",
      "innerBlockCount": 0,
      "fingerprint": "8c418a617d4992dc38018e35d242bda67da153b052ff96762d6138a2e5d098e8",
