      "title": { "type": "string", "maxCharacters": 42, "required": true },
      "body": { "type": "string", "maxCharacters": 92, "maxLines": 3, "required": true },
      "detail": { "type": "string", "maxCharacters": 120, "maxLines": 4, "required": true }
