{
  "template": "CredentialsFull",
  "version": "0.1",
  "viewport": { "width": 1920, "height": 1080 },
  "slots": {
    "sectionLabel": { "selector": "[data-slot='sectionLabel']", "type": "string", "required": false, "constraints": { "maxCharacters": 48, "maxLines": 1, "overflow": "reject" } },
    "title": { "selector": "[data-slot='title']", "type": "rich-string", "required": true, "constraints": { "maxCharacters": 62, "maxLines": 3, "allowedTags": ["em"], "overflow": "reject" } },
    "supporting": { "selector": "[data-slot='supporting']", "type": "string", "required": true, "constraints": { "maxCharacters": 144, "maxLines": 4, "overflow": "reject" } },
    "credentials": { "selector": "[data-slot='credentials']", "type": "array", "required": true, "constraints": { "minItems": 4, "maxItems": 6, "overflow": "reject" }, "item": { "type": "object", "shape": { "brandName": { "type": "string", "required": true, "maxCharacters": 60, "maxLines": 1 }, "brandMark": { "type": "asset-ref", "required": true, "accept": ["image/svg+xml", "image/png", "image/webp"], "description": "approved institutional brand asset; renderer handles optical normalization" }, "relationship": { "type": "string", "required": true, "maxCharacters": 68, "maxLines": 3 }, "evidenceRef": { "type": "string", "required": true, "maxCharacters": 78, "maxLines": 3 } } } }
  },
  "presentation": { "brandSurface": "timeline-full-approved-navy-gradient", "composition": "4–6 evidence-backed credentials in a fixed 3x2 responsive grid", "brandPolicy": "never draw, approximate, or fabricate a logo; asset and evidence are required" }
}
