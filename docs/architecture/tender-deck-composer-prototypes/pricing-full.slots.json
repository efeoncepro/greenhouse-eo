{
  "template": "PricingFull",
  "version": "0.1",
  "viewport": { "width": 1920, "height": 1080 },
  "slots": {
    "sectionLabel": {
      "selector": "[data-slot='sectionLabel']",
      "type": "string",
      "required": false,
      "constraints": { "maxCharacters": 48, "maxLines": 1, "overflow": "reject" }
    },
    "title": {
      "selector": "[data-slot='title']",
      "type": "rich-string",
      "required": true,
      "constraints": { "maxCharacters": 66, "maxLines": 3, "allowedTags": ["em"], "overflow": "reject" }
    },
    "summary": {
      "selector": "[data-slot='summary']",
      "type": "object",
      "required": true,
      "shape": {
        "amount": { "type": "string", "required": true, "maxCharacters": 18, "maxLines": 1 },
        "period": { "type": "string", "required": true, "maxCharacters": 52, "maxLines": 2 },
        "taxNote": { "type": "string", "required": true, "maxCharacters": 56, "maxLines": 2 }
      }
    },
    "pricingOptions": {
      "selector": "[data-slot='pricingOptions']",
      "type": "array",
      "required": true,
      "constraints": { "minItems": 2, "maxItems": 3, "overflow": "reject" },
      "item": {
        "type": "object",
        "shape": {
          "label": { "type": "string", "required": true, "maxCharacters": 44, "maxLines": 1 },
          "status": { "type": "string", "required": false, "maxCharacters": 14, "maxLines": 1 },
          "scope": { "type": "string", "required": true, "maxCharacters": 96, "maxLines": 2 },
          "amount": { "type": "string", "required": true, "maxCharacters": 20, "maxLines": 1 },
          "isProposed": { "type": "boolean", "required": true, "resolver": "pricing-option-tone", "description": "exactly one option must be true; renders the fixed proposed-state treatment" }
        }
      }
    },
    "commercialTerms": {
      "selector": "[data-slot='commercialTerms']",
      "type": "array",
      "required": true,
      "constraints": { "minItems": 2, "maxItems": 3, "overflow": "reject" },
      "item": {
        "type": "object",
        "shape": {
          "label": { "type": "string", "required": true, "maxCharacters": 32, "maxLines": 1 },
          "value": { "type": "string", "required": true, "maxCharacters": 70, "maxLines": 3 }
        }
      }
    }
  },
  "presentation": {
    "brandSurface": "canonical-rich-deck-gradient",
    "composition": "proposed monthly rate hero at top right; one transparent ledger below with mutually exclusive pricing options and commercial terms",
    "pricePolicy": "amounts are supplied as formatted strings; options are alternatives, never summed. The composer must not calculate, invent, or reconcile monetary values"
  }
}
