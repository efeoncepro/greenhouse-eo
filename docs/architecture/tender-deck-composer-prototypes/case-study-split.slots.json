{
  "template": "CaseStudySplit",
  "version": "0.1",
  "viewport": { "width": 1920, "height": 1080 },
  "slots": {
    "sectionLabel": { "selector": "[data-slot='sectionLabel']", "type": "string", "required": false, "constraints": { "maxCharacters": 48, "maxLines": 1, "overflow": "reject" } },
    "title": { "selector": "[data-slot='title']", "type": "rich-string", "required": true, "constraints": { "maxCharacters": 66, "maxLines": 3, "allowedTags": ["em"], "overflow": "reject" } },
    "stages": { "selector": "[data-slot='stages']", "type": "array", "required": true, "constraints": { "minItems": 3, "maxItems": 3, "overflow": "reject", "order": "narrative sequence: contexto/reto → acción/enfoque → aprendizaje" }, "item": { "type": "object", "shape": {
      "label": { "type": "string", "required": true, "maxCharacters": 18, "maxLines": 1 },
      "body": { "type": "rich-string", "required": true, "maxCharacters": 140, "maxLines": 4, "allowedTags": ["b"] }
    } } },
    "resultLabel": { "selector": "[data-slot='resultLabel']", "type": "string", "required": false, "constraints": { "maxCharacters": 22, "maxLines": 1, "overflow": "reject" } },
    "result": { "selector": "[data-slot='result']", "type": "object", "required": true, "constraints": { "quantifiedClaimsRequireEvidenceRef": true }, "shape": {
      "metric": { "type": "string", "required": true, "maxCharacters": 8, "maxLines": 1, "requires": ["evidenceRef"] },
      "metricLabel": { "type": "string", "required": true, "maxCharacters": 54, "maxLines": 3 },
      "evidenceRef": { "type": "string", "required": false, "maxCharacters": 112, "maxLines": 2, "consumer": "validation-only" }
    } },
    "comparison": { "selector": "[data-slot='comparison']", "type": "object", "required": true, "constraints": { "quantifiedClaimsRequireEvidenceRef": true }, "shape": {
      "barScale": { "type": "number", "required": false, "resolver": "case-study-before-after-bar-scale", "consumer": "presentation", "description": "bar heights are derived from beforeValue/afterValue so the visual jump equals the stated jump; never hand-set" },
      "beforeValue": { "type": "string", "required": true, "maxCharacters": 8, "maxLines": 1, "requires": ["evidenceRef"] },
      "beforeCaption": { "type": "string", "required": true, "maxCharacters": 18, "maxLines": 1 },
      "afterValue": { "type": "string", "required": true, "maxCharacters": 8, "maxLines": 1, "requires": ["evidenceRef"] },
      "afterCaption": { "type": "string", "required": true, "maxCharacters": 18, "maxLines": 1 },
      "bridgeTitle": { "type": "rich-string", "required": true, "maxCharacters": 44, "maxLines": 2, "allowedTags": ["br"] },
      "bridgeSubtitle": { "type": "string", "required": true, "maxCharacters": 40, "maxLines": 1 },
      "evidenceRef": { "type": "string", "required": false, "maxCharacters": 112, "maxLines": 2, "consumer": "validation-only" }
    } },
    "supportingClaims": { "selector": "[data-slot='supportingClaims']", "type": "array", "required": false, "constraints": { "minItems": 0, "maxItems": 2, "maxCharactersPerItem": 38, "maxLinesPerItem": 1, "overflow": "reject", "quantifiedClaimsRequireEvidenceRef": true, "evidenceCarrier": "sourceNote — the chip markup has no child element to anchor a per-chip evidenceRef; any figure in a chip must be covered by the slide's sourceNote and by the same accreditation as result.evidenceRef" }, "item": { "type": "rich-string", "allowedTags": ["b"] } },
    "sourceNote": { "selector": "[data-slot='sourceNote']", "type": "string", "required": true, "constraints": { "maxCharacters": 130, "maxLines": 2, "overflow": "reject" } }
  },
  "presentation": { "brandSurface": "canonical-navy-brand-panel-right", "composition": "left = accredited story (reto → enfoque → aprendizaje); right = the payoff (one hero metric + a truthful before/after + supporting chips)", "evidencePolicy": "every quantified claim on this slide requires an evidenceRef; a figure with no source never enters an offer. The visible sourceNote is mandatory and must state whether the case is anonymized and where the real case is accredited" }
}
