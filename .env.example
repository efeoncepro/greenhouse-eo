# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
BASEPATH=
GCP_PROJECT=efeonce-group
GCP_PROJECT_NUMBER=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=true

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=
NEXTAUTH_SECRET_SECRET_REF=
NEXTAUTH_URL=http://localhost:3000
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_CLIENT_SECRET_SECRET_REF=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CLIENT_SECRET_SECRET_REF=
GCP_WORKLOAD_IDENTITY_PROVIDER=
GCP_WORKLOAD_IDENTITY_POOL_ID=
GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=
GCP_SERVICE_ACCOUNT_EMAIL=
GCP_AUTH_PREFERENCE=auto
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_APPLICATION_CREDENTIALS_JSON_BASE64=
GREENHOUSE_PUBLIC_MEDIA_BUCKET=
GREENHOUSE_PRIVATE_ASSETS_BUCKET=
GREENHOUSE_MEDIA_BUCKET=
GREENHOUSE_AGENT_MODEL=gemini-2.5-flash
HUBSPOT_GREENHOUSE_INTEGRATION_BASE_URL=https://hubspot-greenhouse-integration-183008134038.us-central1.run.app
GREENHOUSE_PARTY_LIFECYCLE_SYNC=false
GREENHOUSE_PRICING_APPROVAL_NOTIFICATIONS=false
NOTION_PIPELINE_URL=https://notion-bq-sync-183008134038.us-central1.run.app
NOTION_TOKEN=
NOTION_TOKEN_SECRET_REF=
RESEND_API_KEY=
RESEND_API_KEY_SECRET_REF=
RESEND_WEBHOOK_SIGNING_SECRET=
RESEND_WEBHOOK_SIGNING_SECRET_SECRET_REF=
EMAIL_FROM=Efeonce Greenhouse <greenhouse@efeoncepro.com>
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_INCIDENTS_AUTH_TOKEN=
SENTRY_INCIDENTS_AUTH_TOKEN_SECRET_REF=
SENTRY_ORG=
SENTRY_PROJECT=
SLACK_ALERTS_WEBHOOK_URL=
SLACK_ALERTS_WEBHOOK_URL_SECRET_REF=
CRON_SECRET=
HR_CORE_TEAMS_WEBHOOK_SECRET=
WEBHOOK_CANARY_SECRET=
WEBHOOK_CANARY_SECRET_SECRET_REF=webhook-canary-secret
WEBHOOK_CANARY_VERCEL_PROTECTION_BYPASS_SECRET=
WEBHOOK_NOTIFICATIONS_SECRET=
WEBHOOK_NOTIFICATIONS_SECRET_SECRET_REF=
WEBHOOK_NOTIFICATIONS_VERCEL_PROTECTION_BYPASS_SECRET=
ZAPSIGN_API_BASE_URL=https://api.zapsign.com.br
ZAPSIGN_API_TOKEN=
ZAPSIGN_API_TOKEN_SECRET_REF=
ZAPSIGN_WEBHOOK_SHARED_SECRET=
ZAPSIGN_WEBHOOK_SHARED_SECRET_SECRET_REF=
# Agent / E2E auth — headless session for Playwright, MCP browser, CI
# Generate a random secret: openssl rand -hex 32
AGENT_AUTH_SECRET=
AGENT_AUTH_EMAIL=agent@greenhouse.efeonce.org
# Set to 'true' only if you need agent auth in production (not recommended)
# AGENT_AUTH_ALLOW_PRODUCTION=false

# Playwright E2E smoke suite — see docs/operations/PLAYWRIGHT_E2E.md
# Overrides NEXT_PUBLIC_APP_URL when running `pnpm test:e2e` (e.g. staging .vercel.app)
PLAYWRIGHT_BASE_URL=
# Skip auto auth setup (requires a pre-existing .auth/storageState.json)
# PLAYWRIGHT_SKIP_AUTH_SETUP=false
# Let Playwright start `pnpm dev` automatically (local only)
# PLAYWRIGHT_START_WEB_SERVER=false

# Greenhouse MCP read-only adapter (local stdio server)
GREENHOUSE_MCP_API_BASE_URL=
GREENHOUSE_MCP_CONSUMER_TOKEN=
GREENHOUSE_MCP_EXTERNAL_SCOPE_TYPE=
GREENHOUSE_MCP_EXTERNAL_SCOPE_ID=
# Optional API version override; defaults to 2026-04-25
GREENHOUSE_MCP_API_VERSION=

# Vercel Deployment Protection bypass — auto-fetched by scripts/staging-request.mjs
# DO NOT create this manually in Vercel dashboard — it's system-managed.
# If empty, staging-request.mjs will auto-fetch it via the Vercel API (requires `vercel login`).
VERCEL_AUTOMATION_BYPASS_SECRET=
# Finance BigQuery write control (set to 'false' to stop writing to fin_* tables in BigQuery)
FINANCE_BIGQUERY_WRITE_ENABLED=true
# Reconciliation intelligence is advisory-only. Keep disabled unless suggestions are being validated.
FINANCE_RECONCILIATION_AI_ENABLED=false
# Cloud SQL Connector (preferred for all Node.js environments — no TCP, no proxy needed)
GREENHOUSE_POSTGRES_INSTANCE_CONNECTION_NAME=
GREENHOUSE_POSTGRES_IP_TYPE=PUBLIC
# TCP fallback — only needed for standalone binaries (pg_dump, psql) via Cloud SQL Auth Proxy
GREENHOUSE_POSTGRES_HOST=
GREENHOUSE_POSTGRES_PORT=5432
GREENHOUSE_POSTGRES_DATABASE=
GREENHOUSE_POSTGRES_USER=
GREENHOUSE_POSTGRES_PASSWORD=
GREENHOUSE_POSTGRES_PASSWORD_SECRET_REF=
GREENHOUSE_POSTGRES_MIGRATOR_USER=
GREENHOUSE_POSTGRES_MIGRATOR_PASSWORD=
GREENHOUSE_POSTGRES_MIGRATOR_PASSWORD_SECRET_REF=
GREENHOUSE_POSTGRES_ADMIN_USER=
GREENHOUSE_POSTGRES_ADMIN_PASSWORD=
GREENHOUSE_POSTGRES_ADMIN_PASSWORD_SECRET_REF=
GREENHOUSE_POSTGRES_OPS_USER=greenhouse_ops
GREENHOUSE_POSTGRES_OPS_PASSWORD=
GREENHOUSE_POSTGRES_OPS_PASSWORD_SECRET_REF=greenhouse-pg-dev-ops-password
GREENHOUSE_POSTGRES_MAX_CONNECTIONS=15
GREENHOUSE_POSTGRES_SSL=false
GREENHOUSE_BIGQUERY_DATASET=greenhouse
GREENHOUSE_BIGQUERY_LOCATION=US
NUBOX_API_BASE_URL=
NUBOX_BEARER_TOKEN=
NUBOX_BEARER_TOKEN_SECRET_REF=
NUBOX_X_API_KEY=
NUBOX_X_API_KEY_SECRET_REF=
MERCADO_PUBLICO_TICKET=
MERCADO_PUBLICO_TICKET_SECRET_REF=greenhouse-mercado-publico-ticket
